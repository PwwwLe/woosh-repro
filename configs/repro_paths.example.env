# Copy to .env or source manually before running local wrappers if desired.
CONDA_ENV=woosh
WOOSH_ROOT=Woosh-main
WOOSH_CHECKPOINTS_DIR=Woosh-main/checkpoints
WOOSH_SAMPLES_DIR=Woosh-main/samples
WOOSH_OUTPUTS_DIR=Woosh-main/outputs
WOOSH_EXPERIMENT_DIR=experiments/runs/local
WOOSH_MODEL=Woosh-DFlow
WOOSH_PROMPT=sportscar engine revving and driving away quickly
